# Frontend environment variables.
# Copy this file to `.env` and adjust the values.

# Backend API base URL, read by both the axios client (src/api/http.ts) and the chat
# SSE call (src/api/chat.ts).
#
# LEAVE EMPTY (or unset) for same-origin setups: requests go to a relative "/api",
# which the Vite dev server proxies to the backend (see vite.config.ts) and a
# production reverse proxy (e.g. Nginx) forwards to the API. This is the recommended
# default and needs no value here.
#
# SET AN ABSOLUTE URL only when the frontend and backend are on different origins
# (no shared proxy), e.g. VITE_API_BASE_URL=https://api.example.com
VITE_API_BASE_URL=
