# .gitattributes — cross-platform normalization for the IoT-Verify full-stack repo
#
# Why this file exists: local git here runs core.autocrlf=true, which is
# machine-dependent. .gitattributes makes line-ending policy part of the repo, so every
# checkout is consistent regardless of a contributor's OS or local git settings. This
# prevents "the whole file changed" CRLF/LF diffs between Windows and Linux/macOS.

# ---------------------------------------------------------------------------
# Default: let git detect text vs binary and normalize text to LF in the repo.
# ---------------------------------------------------------------------------
* text=auto

# ---------------------------------------------------------------------------
# Text files — store as LF in the repo AND check out as LF everywhere.
# Pinning eol=lf (not just `text`) stops Windows checkouts from re-introducing CRLF
# into files that tooling runs on cross-platform (scripts, YAML, source).
# ---------------------------------------------------------------------------

# Source
*.java   text eol=lf
*.ts     text eol=lf
*.tsx    text eol=lf
*.js     text eol=lf
*.jsx    text eol=lf
*.vue    text eol=lf
*.mjs    text eol=lf
*.cjs    text eol=lf
*.css    text eol=lf
*.scss   text eol=lf
*.html   text eol=lf

# Config & data
*.json   text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.xml    text eol=lf
*.properties text eol=lf
*.toml   text eol=lf
*.env    text eol=lf
.editorconfig text eol=lf

# Docs
*.md     text eol=lf
*.txt    text eol=lf

# NuSMV model / verification sources are plain text — keep LF so behavior matches the
# parser (which depends on NuSMV's line-based output) on every platform.
*.smv    text eol=lf

# Shell / POSIX scripts MUST be LF or they break when run on Linux/macOS.
*.sh     text eol=lf
mvnw     text eol=lf
gradlew  text eol=lf

# ---------------------------------------------------------------------------
# Windows-only scripts — must stay CRLF to run under cmd.exe.
# ---------------------------------------------------------------------------
*.bat    text eol=crlf
*.cmd    text eol=crlf
*.ps1    text eol=crlf

# ---------------------------------------------------------------------------
# Binary files — never normalize, never diff as text (avoids corruption and noise).
# ---------------------------------------------------------------------------
# Images
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.webp   binary
# SVG is XML/text, but treat as binary to avoid line-ending churn across the large
# asset set under frontend/src/assets/. Switch to `text` if you need to diff them.
*.svg    binary

# Fonts
*.woff   binary
*.woff2  binary
*.ttf    binary
*.eot    binary
*.otf    binary

# Archives & compiled artifacts (also gitignored, but pin as binary defensively)
*.jar    binary
*.war    binary
*.class  binary
*.zip    binary
*.tar.gz binary
*.rar    binary
*.pdf    binary

# Office documents (e.g. the project proposal .docx) — binary, do not diff.
*.docx   binary
*.doc    binary
*.xlsx   binary
*.pptx   binary

# ---------------------------------------------------------------------------
# Linguist / diff hints (GitHub language stats + review readability)
# ---------------------------------------------------------------------------
frontend/package-lock.json linguist-generated=true -diff
frontend/dist/**           linguist-generated=true
backend/target/**          linguist-generated=true
docs/**                    linguist-documentation=true
