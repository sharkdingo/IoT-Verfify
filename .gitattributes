# .gitattributes — cross-platform normalization for the IoT-Verify full-stack repo
#
# Why this file exists: local git here runs core.autocrlf=true, which is
# machine-dependent. .gitattributes makes line-ending policy part of the repo, so every
# checkout is consistent regardless of a contributor's OS or local git settings. This
# prevents "the whole file changed" CRLF/LF diffs between Windows and Linux/macOS.
#
# Note: .gitattributes does not support EditorConfig keys such as `root`, `charset`,
# or `end_of_line`. Use .editorconfig for editor behavior and this file for Git's
# normalization behavior.

[attr]utf8lf text eol=lf working-tree-encoding=UTF-8

# ---------------------------------------------------------------------------
# Default: let git detect text vs binary and normalize detected text to LF.
# ---------------------------------------------------------------------------
* text=auto eol=lf

# ---------------------------------------------------------------------------
# Text files — UTF-8 in the working tree, LF in the repo and checkout.
# ---------------------------------------------------------------------------

# Source
*.java   utf8lf
*.ts     utf8lf
*.tsx    utf8lf
*.js     utf8lf
*.jsx    utf8lf
*.vue    utf8lf
*.mjs    utf8lf
*.cjs    utf8lf
*.css    utf8lf
*.scss   utf8lf
*.html   utf8lf

# Config & data
*.json   utf8lf
*.yaml   utf8lf
*.yml    utf8lf
*.xml    utf8lf
*.properties utf8lf
*.toml   utf8lf
*.env    utf8lf
.editorconfig utf8lf
.gitattributes utf8lf
.gitignore utf8lf

# Docs
*.md     utf8lf
*.txt    utf8lf

# NuSMV model / verification sources are plain text — keep LF so behavior matches the
# parser (which depends on NuSMV's line-based output) on every platform.
*.smv    utf8lf

# Scripts
*.sh     utf8lf
*.bat    utf8lf
*.cmd    utf8lf
*.ps1    utf8lf
mvnw     utf8lf
gradlew  utf8lf

# ---------------------------------------------------------------------------
# Binary files — never normalize, never diff as text (avoids corruption and noise).
# ---------------------------------------------------------------------------
# Images
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.webp   binary
# SVG is XML/text, but treat as binary to avoid line-ending churn across the large
# asset set under frontend/src/assets/. Switch to `text` if you need to diff them.
*.svg    binary

# Fonts
*.woff   binary
*.woff2  binary
*.ttf    binary
*.eot    binary
*.otf    binary

# Archives & compiled artifacts (also gitignored, but pin as binary defensively)
*.jar    binary
*.war    binary
*.class  binary
*.zip    binary
*.tar.gz binary
*.rar    binary
*.pdf    binary

# Office documents (e.g. the project proposal .docx) — binary, do not diff.
*.docx   binary
*.doc    binary
*.xlsx   binary
*.pptx   binary

# ---------------------------------------------------------------------------
# Linguist / diff hints (GitHub language stats + review readability)
# ---------------------------------------------------------------------------
frontend/package-lock.json linguist-generated=true -diff
frontend/dist/**           linguist-generated=true
backend/target/**          linguist-generated=true
docs/**                    linguist-documentation=true
